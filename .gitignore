.DS_Store
**/.DS_Store
node_modules/

# Stray root lockfile: the npm projects live in tools/ and site/, so there is
# no root package.json. Ignore an accidental root lockfile (the subproject
# lockfiles are committed normally).
/package-lock.json

# Site build output (regenerated by CI on deploy)
site/dist/

# Secrets
tools/.env

# Original-quality source media is kept OUT of git (large). The optimized,
# derived media in site/public/media IS committed and is what the site serves.
# Keep the original data export as your offline backup of these.
content/stories/**/source.m4a
content/stories/**/source.png
# Same for character reference images: originals stay local, the optimized
# site/public/media/characters/*.webp derived from them IS committed.
content/characters/**/reference.*

# Reference-only originals (the AI Studio app + the raw data exports).
# These are not part of the new project; keep them locally as a backup.
stars-and-stories-archive/
StarsAndStories_GitHub_Export_2026-06-21/
StarsAndStories_World_Inventory_*/
