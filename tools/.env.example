# Copy to .env and fill in. Only the Gemini-backed tools (add-story, gen-world-dna,
# verify-models) need this. import-export and build-site do NOT use Gemini.
GEMINI_API_KEY=your-key-here

# Optional overrides if the default model names are no longer valid.
# GEMINI_TEXT_MODEL=gemini-3.5-flash
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
